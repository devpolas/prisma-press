model User {
  id String @id @default(uuid())
  name String @db.VarChar(255)
  email String @unique
  role Role @default(USER)
  password String
  activeStatus ActiveStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?
  subscription Subscription?
  posts Post[]
  comments Comment[]
  

  
  @@map("users")
}